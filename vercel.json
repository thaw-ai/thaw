{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd site && npm install --no-audit --no-fund",
  "buildCommand": "cd site && npm run build",
  "outputDirectory": "site/.next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- site vercel.json"
}
