# ============================================================================
# Rust
# ============================================================================
# Cargo's build output. Huge (gigabytes), fully reproducible from source.
target/
# Emacs/rustfmt backup files.
**/*.rs.bk
# We DO commit Cargo.lock for binary crates (reproducible builds).
# If this were a library-only workspace we'd ignore it. It's not.
# ============================================================================
# C++ / CUDA
# ============================================================================
# CMake and nvcc build artifacts (when cpp/thaw-cuda starts building).
cpp/**/build/
cpp/**/cmake-build-*/
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.pdb
*.ilk
# nvcc intermediate files.
*.cubin
*.fatbin
*.ptx
*.sass
# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
pip-log.txt
pip-delete-this-directory.txt
# ============================================================================
# Reading material — copyrighted papers and PDFs
# ============================================================================
# We keep PDFs locally for Phase 0 reading but don't commit them.
# They're linked to in docs/READING.md and can be downloaded from arxiv
# or NVIDIA. Copyrights belong to the authors.
readings/*.pdf

# ============================================================================
# thaw runtime artifacts
# ============================================================================
# Actual snapshot files — potentially gigabytes, never commit.
*.thaw
# Benchmark output directories.
snapshots/
benchmarks/results/
bench_results/
# Any downloaded model weights (these live outside the repo normally,
# but in case someone pulls Llama weights into a subfolder by mistake).
models/
weights/
*.safetensors
*.bin
*.gguf
# ============================================================================
# Editors and OS
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
# ============================================================================
# Secrets and local config
# ============================================================================
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
# ============================================================================
# Logs and profiling
# ============================================================================
*.log
*.nvprof
*.nsys-rep
*.qdrep
perf.data
perf.data.old
# ============================================================================
# Don't ignore
# ============================================================================
# Explicitly keep empty-directory markers if we need them.
!.gitkeep
# Golden-file test fixtures. These are committed on purpose so that
# format drift shows up as a diff in CI. The `*.bin` rule above is
# for model weights; our own test goldens are the exception.
!crates/**/tests/goldens/**
claudes_corner/

dist/

# ============================================================================
# Internal / strategy docs — not for public repo
# ============================================================================
# This repo IS the public repo. Anything internal (plans, decks, research,
# strategy docs, partner notes) lives locally but is never tracked. The
# old private→public sync workflow is gone — work directly here and PR.
DESIGN.md
/plans/
/private/
/legacy-site/
/pitch-deck.html
/sync-public.sh
CLAUDE.md
docs/STRATEGY.md
docs/LANDSCAPE.md
docs/STACK.md
docs/TESTING.md
docs/GLOSSARY.md
docs/KEY_INSIGHTS.md
docs/ONBOARDING.md
docs/READING.md
docs/RELEASING.md
docs/notes/
.claude/
# ============================================================================
# Local scratch / large media — kept out of the repo (use a release or the
# site's own assets for anything that needs to be public).
# ============================================================================
*.mp4
*.Rhistory
/thaw demo videos/
# arXiv submission bundle — generated/local, may contain pre-publication scratch.
paper/refeed-drift/arxiv-upload/
# codebase-memory-mcp index — local, regenerated per machine via index_repository
# (1.8 MB binary that changes on every re-index). Commit it instead if you want
# teammates to bootstrap the graph without re-indexing.
.codebase-memory/
